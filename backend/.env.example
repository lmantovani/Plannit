# Lider Moveis — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# === BANCO DE DADOS ===
DATABASE_URL=postgresql://postgres:senha@localhost:5432/lider_moveis

# === JWT / AUTENTICAÇÃO ===
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === SERVIDOR ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
DEBUG=true

# === CORS (Frontend URLs permitidas) ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === EMAIL (configurar na Fase 2) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=email@empresa.com
# SMTP_PASSWORD=senha

# === PRIMEIRO USUÁRIO ADMIN ===
FIRST_ADMIN_EMAIL=admin@lidermoveis.com.br
FIRST_ADMIN_PASSWORD=Admin@123456
FIRST_ADMIN_NAME=Administrador
